{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "last_message_preview": {
      "type": "string"
    },
    "last_activity_date": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "title"
  ],
  "rls": {
    "create": true,
    "read": {
      "created_by": "{{user.email}}"
    },
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}