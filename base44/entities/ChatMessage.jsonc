{
  "name": "ChatMessage",
  "type": "object",
  "properties": {
    "conversation_id": {
      "type": "string",
      "default": "default"
    },
    "role": {
      "type": "string",
      "enum": [
        "user",
        "assistant"
      ],
      "required": true
    },
    "content": {
      "type": "string",
      "required": true
    }
  },
  "required": [
    "role",
    "content"
  ]
}